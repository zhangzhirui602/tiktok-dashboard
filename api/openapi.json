{
  "openapi": "3.1.0",
  "info": {
    "title": "TikTok Dashboard API",
    "description": "HTTP wrapper over the tiktok-dashboard business logic (BGM / prompts / jobs / pipeline stages). Local use only — no auth, paths are hard-coded to the developer's sibling repos.",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/bgm": {
      "get": {
        "tags": [
          "bgm"
        ],
        "summary": "List Bgm",
        "description": "List all BGM files in assets/bgm/.",
        "operationId": "list_bgm_api_v1_bgm_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/BGMItem"
                  },
                  "type": "array",
                  "title": "Response List Bgm Api V1 Bgm Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "bgm"
        ],
        "summary": "Upload Bgm",
        "description": "Upload a BGM file (multipart/form-data).",
        "operationId": "upload_bgm_api_v1_bgm_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_bgm_api_v1_bgm_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BGMItem"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/bgm/{name}/metadata": {
      "get": {
        "tags": [
          "bgm"
        ],
        "summary": "Get Metadata",
        "description": "Analyze BGM and return name/path/size/duration/bpm.",
        "operationId": "get_metadata_api_v1_bgm__name__metadata_get",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BGMItem"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/bgm/{name}/analyze": {
      "post": {
        "tags": [
          "bgm"
        ],
        "summary": "Analyze",
        "description": "Trigger BPM/duration analysis and return the raw analysis dict.",
        "operationId": "analyze_api_v1_bgm__name__analyze_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BGMAnalyzeResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/bgm/{name}": {
      "delete": {
        "tags": [
          "bgm"
        ],
        "summary": "Delete",
        "operationId": "delete_api_v1_bgm__name__delete",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/prompts/expand": {
      "post": {
        "tags": [
          "prompts"
        ],
        "summary": "Expand",
        "description": "Generate N Seedance prompts from song/artist/style via ARK Doubao.\n\nRequires ARK_API_KEY (and ARK_TEXT_ENDPOINT) in the environment.",
        "operationId": "expand_api_v1_prompts_expand_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptExpandRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptExpandResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "List Jobs",
        "description": "List all jobs (newest first).",
        "operationId": "list_jobs_api_v1_jobs_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/JobSummary"
                  },
                  "type": "array",
                  "title": "Response List Jobs Api V1 Jobs Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Create Job",
        "description": "Create a new job and persist state.json under tmp/jobs/{id}/.",
        "operationId": "create_job_api_v1_jobs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Get Job",
        "operationId": "get_job_api_v1_jobs__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "jobs"
        ],
        "summary": "Update Job",
        "description": "Partial update — overwrites any of overall_status / clips / stages / params.",
        "operationId": "update_job_api_v1_jobs__job_id__patch",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/drafts": {
      "get": {
        "tags": [
          "drafts"
        ],
        "summary": "List Drafts",
        "description": "Jobs still in 'creating' state (not yet sent to generation).",
        "operationId": "list_drafts_api_v1_drafts_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/JobSummary"
                  },
                  "type": "array",
                  "title": "Response List Drafts Api V1 Drafts Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/drafts/{job_id}/approve": {
      "post": {
        "tags": [
          "drafts"
        ],
        "summary": "Approve Draft",
        "description": "Move a draft out of 'creating' — marks it ready for generation.",
        "operationId": "approve_draft_api_v1_drafts__job_id__approve_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/generate": {
      "post": {
        "tags": [
          "pipeline"
        ],
        "summary": "Generate",
        "description": "Trigger Seedance clip generation for all pending clips.",
        "operationId": "generate_api_v1_jobs__job_id__generate_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StageTriggerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/whisper": {
      "post": {
        "tags": [
          "pipeline"
        ],
        "summary": "Whisper",
        "description": "Trigger Whisper subtitle generation for the merged video.",
        "operationId": "whisper_api_v1_jobs__job_id__whisper_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StageTriggerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/merge": {
      "post": {
        "tags": [
          "pipeline"
        ],
        "summary": "Merge",
        "description": "Trigger FFmpeg merge of confirmed clips with the job's BGM.",
        "operationId": "merge_api_v1_jobs__job_id__merge_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StageTriggerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BGMAnalyzeResult": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "duration_s": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration S"
          },
          "bpm": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bpm"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "name",
          "duration_s",
          "bpm"
        ],
        "title": "BGMAnalyzeResult"
      },
      "BGMItem": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "path": {
            "type": "string",
            "title": "Path"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes"
          },
          "duration_s": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration S"
          },
          "bpm": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bpm"
          }
        },
        "type": "object",
        "required": [
          "name",
          "path",
          "size_bytes"
        ],
        "title": "BGMItem"
      },
      "Body_upload_bgm_api_v1_bgm_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_bgm_api_v1_bgm_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "JobCreateRequest": {
        "properties": {
          "prompts": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Prompts"
          },
          "tiktok_accounts": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tiktok Accounts"
          },
          "bgm_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bgm Path"
          },
          "resolution": {
            "type": "string",
            "title": "Resolution",
            "default": "480p"
          },
          "ratio": {
            "type": "string",
            "title": "Ratio",
            "default": "9:16"
          },
          "duration": {
            "type": "integer",
            "title": "Duration",
            "default": 5
          },
          "beats_per_cut": {
            "type": "integer",
            "title": "Beats Per Cut",
            "default": 2
          },
          "bpm": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Bpm"
          },
          "song": {
            "type": "string",
            "title": "Song",
            "default": ""
          },
          "artist": {
            "type": "string",
            "title": "Artist",
            "default": ""
          },
          "subtitle_mode": {
            "type": "string",
            "title": "Subtitle Mode",
            "default": "whisper"
          },
          "subtitle_display": {
            "type": "string",
            "title": "Subtitle Display",
            "default": "word"
          },
          "whisper_model": {
            "type": "string",
            "title": "Whisper Model",
            "default": "medium"
          },
          "whisper_language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Whisper Language"
          },
          "scheduled_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scheduled At"
          },
          "tiktok_bgm_song": {
            "type": "string",
            "title": "Tiktok Bgm Song",
            "default": ""
          },
          "tiktok_bgm_artist": {
            "type": "string",
            "title": "Tiktok Bgm Artist",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "prompts"
        ],
        "title": "JobCreateRequest"
      },
      "JobDetail": {
        "properties": {
          "data": {
            "additionalProperties": true,
            "type": "object",
            "title": "Data"
          }
        },
        "type": "object",
        "required": [
          "data"
        ],
        "title": "JobDetail",
        "description": "Full job state — raw JSON from state.json."
      },
      "JobSummary": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "song": {
            "type": "string",
            "title": "Song"
          },
          "artist": {
            "type": "string",
            "title": "Artist"
          },
          "overall_status": {
            "type": "string",
            "title": "Overall Status"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "title": "Updated At"
          },
          "clip_counts": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Clip Counts"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "song",
          "artist",
          "overall_status",
          "created_at",
          "updated_at",
          "clip_counts"
        ],
        "title": "JobSummary"
      },
      "JobUpdateRequest": {
        "properties": {
          "overall_status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Overall Status"
          },
          "clips": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": true,
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Clips"
          },
          "stages": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stages"
          },
          "params": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Params"
          }
        },
        "type": "object",
        "title": "JobUpdateRequest",
        "description": "Partial update — any subset of mutable fields."
      },
      "PromptExpandRequest": {
        "properties": {
          "song": {
            "type": "string",
            "title": "Song",
            "description": "Song title"
          },
          "artist": {
            "type": "string",
            "title": "Artist",
            "description": "Artist name"
          },
          "n": {
            "type": "integer",
            "maximum": 60.0,
            "minimum": 1.0,
            "title": "N",
            "description": "Number of prompts to generate"
          },
          "style": {
            "type": "string",
            "title": "Style",
            "description": "Optional MV style / mother prompt",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "song",
          "artist",
          "n"
        ],
        "title": "PromptExpandRequest"
      },
      "PromptExpandResponse": {
        "properties": {
          "prompts": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Prompts"
          }
        },
        "type": "object",
        "required": [
          "prompts"
        ],
        "title": "PromptExpandResponse"
      },
      "StageTriggerResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "stage": {
            "type": "string",
            "title": "Stage"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": "started"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "default": "Stage scheduled in background. Poll GET /jobs/{job_id} for progress."
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "stage"
        ],
