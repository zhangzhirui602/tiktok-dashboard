# ─── Seedance (Volcengine ARK) ─────────────────────────────────────────────────
# Get your key at: https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here

# ─── TikTok Accounts ──────────────────────────────────────────────────────────
# Format: TIKTOK_COOKIES_<ACCOUNT_NAME>=<path to Netscape cookies.txt>
# The account name will appear in the dashboard dropdown (case-insensitive).
# Export cookies from your browser using a "cookies.txt" extension.
#
TIKTOK_COOKIES_ACCOUNT1=/path/to/account1_cookies.txt
TIKTOK_COOKIES_ACCOUNT2=/path/to/account2_cookies.txt

# ─── Video Editor (Video-Editing-FFmpeg-librosa-Whisper-) ─────────────────────
# These variables are read by the video editor's own .env file inside its
# project directory. Configure them there, not here.
#
# Required in the video editor's .env:
#   AUDIO_PATH=        path to the BGM / narration audio file
#   LANGUAGE=          audio language code, e.g. zh or en
#   SPLIT_MODE=        word | comma | sentence | none
#   WHISPER_MODEL=     tiny | base | small | medium | large
#   VIDEO_WIDTH=       e.g. 1080
#   VIDEO_HEIGHT=      e.g. 1920
#   FPS=               e.g. 30
